# Gemini
GEMINI_API_KEY=

# Neon — get the connection string at neon.tech → your project → Connection Details
DATABASE_URL=

# Neynar (Farcaster)
NEYNAR_API_KEY=

# Base RPC
NEXT_PUBLIC_BASE_SEPOLIA_RPC=
NEXT_PUBLIC_BASE_MAINNET_RPC=

# BuilderRegistry contract (filled after deploy)
NEXT_PUBLIC_REGISTRY_ADDRESS_SEPOLIA=
NEXT_PUBLIC_REGISTRY_ADDRESS_MAINNET=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_CHAIN=sepolia

# Farcaster miniapp manifest (run: npx @farcaster/create-miniapp sign-manifest --domain your-app.vercel.app)
FARCASTER_MANIFEST_HEADER=
FARCASTER_MANIFEST_PAYLOAD=
FARCASTER_MANIFEST_SIGNATURE=
